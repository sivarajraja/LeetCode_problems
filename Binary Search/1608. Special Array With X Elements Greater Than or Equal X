class Solution {
public:
    int specialArray(vector<int>& nums) {
        int n = nums.size();
        sort(nums.begin(),nums.end());

        for(int x=1; x<=100; x++){
            int pos = lower_bound(nums.begin(),nums.end(),x) - nums.begin();
            if(n-pos == x) return x;
        }

        return -1;
    }
};
