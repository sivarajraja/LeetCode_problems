class Solution {
    boolean isPossible(int[] bloomDay, int m, int k,int minDay){
        int n = bloomDay.length;

        int count = 0;
        int low = 0;

        int highVal = 0;
        //int highPos = 0;

        for(int high = 0; high<n; high++){
            highVal = Math.max(highVal,bloomDay[high]);

            if(highVal>minDay){
                low = high+1;
                highVal = 0;
                continue;
            }

            if(high-low+1 == k){
                count++;
                low = high+1;
                highVal = 0;
            }
        }

        //cout<<minDay<<" - "<<count<<endl;
        return count>=m;
    }

    public int minDays(int[] bloomDay, int m, int k) {
        int n = bloomDay.length;
        if(n<((long)m*k)) return -1;

        int low = 0,high = 1000000009;
        int ans = 0;

        while(low<=high){
            int mid = low+(high-low)/2;

            if(isPossible(bloomDay,m,k,mid)){
                ans = mid;
                high = mid-1;
            }
            else{
                low = mid+1;
            }
        }

        return ans;
    }
}
