class Solution {
public:
    long long minEnd(int n, int x) {
        long long ans = x;
        long long rem = n-1;

        while(rem){
            for(int i=0; i<64; i++){
                if(!(ans&((long long)1<<i))){
                    ans |= ((rem&1)<<i);
                    rem = rem/2;
                }
            }
        }

        return ans;
    }
};
