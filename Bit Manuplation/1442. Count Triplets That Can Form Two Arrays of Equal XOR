class Solution {
public:
    int countTriplets(vector<int>& arr) {
        int count = 0;
        int n = arr.size();

        if(n<2) return 0;

        vector<int> prefixXor(n+1,0);
        for(int i=0; i<n; i++){
            prefixXor[i+1] = prefixXor[i]^arr[i];
        }

        for(int i=0; i<n; i++){
            for(int k=i+1; k<=n; k++){
                if(prefixXor[i] == prefixXor[k]){
                    count += k - (i+1);
                }
            }
        }

        return count;
    }
};
