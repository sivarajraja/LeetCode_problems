class Solution {
public:
    int ans = 20;

    void func(int pos,vector<pair<int,int>> &emptyPos,vector<vector<int>>& grid,int moves){
        if(pos == emptyPos.size()){
            ans = min(ans,moves);
            return;
        }

        int curRow = emptyPos[pos].first;
        int curCol = emptyPos[pos].second;

        for(int i=0; i<3; i++){
            for(int j=0; j<3; j++){
                if(grid[i][j] > 1){
                    int curMoves = abs(i-curRow)+abs(curCol-j);
                    grid[i][j]--;
                    func(pos+1,emptyPos,grid,moves+curMoves);
                    grid[i][j]++;
                }
            }
        }
    }

    int minimumMoves(vector<vector<int>>& grid) {
        vector<pair<int,int>> emptyPos;
        int n = 3;

        for(int i=0; i<n; i++){
            for(int j=0; j<n; j++){
                if(grid[i][j] == 0){
                    emptyPos.push_back({i,j});
                }
            }
        }

        func(0,emptyPos,grid,0);

        return ans;
    }
};
