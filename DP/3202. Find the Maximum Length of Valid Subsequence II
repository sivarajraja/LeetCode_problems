class Solution {
public:
    int maximumLength(vector<int>& nums, int k) {
        int n = nums.size();
        vector<vector<int>> dp(k,vector<int>(k,0));
        int ans = 0;
        for(int i=0; i<n; i++){
            int curRem = nums[i]%k;
            for(int j=0; j<k; j++){
                dp[curRem][j] = max(dp[curRem][j],dp[j][curRem]+1);
                ans = max(ans,dp[curRem][j]);
            }
        }
        return ans;
    }
};
