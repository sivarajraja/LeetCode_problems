class Solution {
public:
    int maximumLength(vector<int>& nums) {
        int n = nums.size();
        //vector<int> modArray(n);

        int zeroCount = 0;
        int oneCount = 0;
        int oppCount = 1;
        int turn = 1-(nums[0]%2);

        for(int i=0; i<n; i++){

            if(nums[i]%2) oneCount++;
            else zeroCount++;

            if(turn == nums[i]%2){
                oppCount++;
                turn = 1-turn;
            }
        }

        return max({zeroCount,oneCount,oppCount});
    }
};
