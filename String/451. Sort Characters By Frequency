class Solution {
public:
    string frequencySort(string s) {

        unordered_map<char,int> freq;
        for(char c:s){
            freq[c]++;
        }

        vector<pair<int,char>> pr;

        for(auto &it:freq){
            pr.push_back({it.second,it.first});
        }

        sort(pr.begin(),pr.end(),[](pair<int,char> &a,pair<int,char> &b){
            if(a.first == b.first) return a.second<b.second;
            return a.first>b.first;
        });

        string ans = "";

        for(int i=0; i<pr.size(); i++){
            int count = pr[i].first;
            char c = pr[i].second;

            for(int j=0; j<count; j++){
                ans.push_back(c);
            }
        }

        return ans;
    }
};
