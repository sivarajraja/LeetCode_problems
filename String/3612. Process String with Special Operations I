class Solution {
public:
    string processStr(string s) {
        string result ="";

        for(char c:s){

            if(isalpha(c)){
                result.push_back(c);
            }
            else if(c == '*'){
                if(result.size()>0) result.pop_back();
            }
            else if(c == '#'){
                string cpy = result;
                result += cpy;
            }
            else{
                reverse(result.begin(),result.end());
            }
        }

        return result;
    }
};
