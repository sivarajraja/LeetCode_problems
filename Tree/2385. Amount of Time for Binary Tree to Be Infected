/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    int ans = 0;

    pair<bool,int> findLCA(TreeNode* node, int start){

        if(!node) return {false,0};

        pair<bool,int> lchild = findLCA(node->left,start);
        pair<bool,int> rchild = findLCA(node->right,start);

        if(node->val == start){
            ans = max(lchild.second,rchild.second);
            return {true,1};
        }
        else{
            if(lchild.first){
                ans = max(ans,lchild.second+rchild.second);
                return {true,lchild.second+1};
            }
            else if(rchild.first){
                ans = max(ans,lchild.second+rchild.second);
                return {true,rchild.second+1};
            }
            else{
                return {false,max(rchild.second,lchild.second)+1};
            }
        }

        return {false,0};
    }
    
    int amountOfTime(TreeNode* root, int start) {
        findLCA(root,start);
        return ans;
    }
};
