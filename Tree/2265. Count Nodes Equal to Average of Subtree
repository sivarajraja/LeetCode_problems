/**
 * Definition for a binary tree node.
 * struct TreeNode {
 *     int val;
 *     TreeNode *left;
 *     TreeNode *right;
 *     TreeNode() : val(0), left(nullptr), right(nullptr) {}
 *     TreeNode(int x) : val(x), left(nullptr), right(nullptr) {}
 *     TreeNode(int x, TreeNode *left, TreeNode *right) : val(x), left(left), right(right) {}
 * };
 */
class Solution {
public:
    int ans = 0;

    pair<int,int> func(TreeNode* node){
        
        if(!node->left && !node->right){
            ans++;
            return {node->val,1};
        }

        pair<int,int> l = {0,0} ,r = {0,0};

        if(node->left)  l = func(node->left);
        if(node->right) r = func(node->right);

        int sum = l.first+r.first+node->val;
        int child = l.second+r.second+1;
        int average = round(sum/child);

        if(average == node->val){
            ans++;
            cout<<node->val<<endl;
        }

        return {sum,child};
    }

    int averageOfSubtree(TreeNode* root) {
        func(root);
        return ans;
    }
};
