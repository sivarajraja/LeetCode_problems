    long long dfs(int u,
              vector<vector<int>>& adj,
              vector<int>& baseTime)
    {
        if(adj[u].empty())
            return baseTime[u];

        long long mn = LLONG_MAX;
        long long mx = LLONG_MIN;

        for(int v : adj[u]){
            long long t = dfs(v, adj, baseTime);
            mn = min(mn, t);
            mx = max(mx, t);
        }

        return mx + (mx - mn) + baseTime[u];
    }

    long long finishTime(int n, vector<vector<int>>& edges, vector<int>& baseTime) {
        vector<vector<int>> adj(n);

        for(auto &it:edges){
            int u = it[0];
            int v = it[1];

            adj[u].push_back(v);
        }

        long long ans = dfs(0,adj,baseTime);

        return ans;
    }
