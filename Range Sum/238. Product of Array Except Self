class Solution {
public:
    vector<int> productExceptSelf(vector<int>& nums) {
        int n = nums.size();

        if(n == 1) return {0};
        if(n == 2) return {nums[1],nums[0]};

        vector<int> prefix(n,1);
        vector<int> suffix(n,1);

        prefix[0] = nums[0];
        for(int i=1; i<n; i++){
            prefix[i] = prefix[i-1]*nums[i];
        }

        suffix[n-1] = nums[n-1];
        for(int i=n-2; i>=0; i--){
            suffix[i] = suffix[i+1]*nums[i];
        }

        vector<int> ans(n,0);
        ans[0] = suffix[1];
        ans[n-1] = prefix[n-2];

        for(int i=1; i<n-1; i++){
            ans[i] = suffix[i+1] * prefix[i-1];
        }

        return ans;
    }
};
