class Solution {
public:
    void sortColors(vector<int>& nums) {
        int n = nums.size();
        int zeroCount = 0,oneCount = 0;

        for(int i=0; i<n; i++){
            if(nums[i] == 0){
                zeroCount++;
            }
            else if(nums[i] == 1){
                oneCount++;
            }
        }

        for(int i=0; i<n; i++){
            if(zeroCount){
                zeroCount--;
                nums[i] = 0;
            }
            else if(oneCount){
                oneCount--;
                nums[i] = 1;
            }
            else{
                nums[i] = 2;
            }
        }

    }
};
